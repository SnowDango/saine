  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "pngjs": "^7.0.0",
    "prettier": "3.2.4",
    "typescript": "5.3.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*"
